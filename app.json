{
  "expo": {
    "name": "pick-and-go",
    "slug": "pick-and-go",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/logo-secondary.png",
    "scheme": "pickandgo",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F5F5F5",
    "ios": {
      "icon": "./assets/images/logo-secondary.png",
      "supportsTablet": true,
      "requireFullScreen": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F5F5",
        "foregroundImage": "./assets/images/logo-secondary.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.nhl007.pickandgo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F5F5",
          "android": {
            "image": "./assets/images/logo-secondary.png",
            "imageWidth": 100
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
